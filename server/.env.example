# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/portfolio_cms?retryWrites=true&w=majority

# Security (CORS)
CLIENT_URL=http://localhost:3000

# JWT Secrets (Phase 3)
JWT_SECRET=super_secret_session_jwt_key_development_only
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=super_secret_refresh_jwt_key_development_only
JWT_REFRESH_EXPIRES_IN=7d

# Media Upload (Cloudinary - Phase 4)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
